# Google Maps API Key (Directions API) — required for trip planning
GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# LLM assistant (OpenAI-compatible endpoint). Default: z.ai GLM-4.7-Flash (free tier).
# Get a key at https://z.ai — leave unset to run with keyword-only assistant fallback.
LLM_API_KEY=
LLM_BASE_URL=https://api.z.ai/api/paas/v4
LLM_MODEL=glm-4.7-flash
